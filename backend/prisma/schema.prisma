generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("HR")
  active       Boolean  @default(true)
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  createdAt    DateTime @default(now())
}

model Company {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  users       User[]
  employees   Employee[]
  phaseAccess PhaseAccess[]
  createdAt   DateTime      @default(now())
}

model OnboardingProcess {
  id          String   @id @default(cuid())
  title       String
  description String?
  phases      Phase[]
  createdAt   DateTime @default(now())
}

model Phase {
  id          String              @id @default(cuid())
  title       String
  order       Int
  processId   String
  process     OnboardingProcess   @relation(fields: [processId], references: [id])
  questions   Question[]
  employees   Employee[]          @relation("CurrentPhase")
  phaseAccess PhaseAccess[]
}

model PhaseAccess {
  id        String  @id @default(cuid())
  companyId String
  phaseId   String
  company   Company @relation(fields: [companyId], references: [id])
  phase     Phase   @relation(fields: [phaseId], references: [id])

  @@unique([companyId, phaseId])
}

model Question {
  id       String           @id @default(cuid())
  label    String
  type     String
  required Boolean          @default(true)
  order    Int
  phaseId  String
  phase    Phase            @relation(fields: [phaseId], references: [id])
  options  QuestionOption[]
  answers  Answer[]
}

model QuestionOption {
  id         String   @id @default(cuid())
  label      String
  value      String
  order      Int
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
}

model Employee {
  id             String    @id @default(cuid())
  name           String
  email          String?
  cpf            String    @unique
  status         String    @default("IN_PROGRESS")
  feedback       String?
  corrections    String[]  @default([])
  hasAccessed    Boolean   @default(false)
  firstAccessAt  DateTime?
  currentPhaseId String?
  currentPhase   Phase?    @relation("CurrentPhase", fields: [currentPhaseId], references: [id])
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id])
  address        Address?
  answers        Answer[]
  documents      Document[]
  createdAt      DateTime  @default(now())
}

model Address {
  id           String   @id @default(cuid())
  employeeId   String   @unique
  employee     Employee @relation(fields: [employeeId], references: [id])
  cep          String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  createdAt    DateTime @default(now())
}

model Answer {
  id         String     @id @default(cuid())
  employeeId String
  questionId String
  value      String
  employee   Employee   @relation(fields: [employeeId], references: [id])
  question   Question   @relation(fields: [questionId], references: [id])
  documents  Document[]
  createdAt  DateTime   @default(now())

  @@unique([employeeId, questionId])
}

model Document {
  id         String   @id @default(cuid())
  fileName   String
  mimeType   String
  fileData   Bytes
  employeeId String
  answerId   String
  employee   Employee @relation(fields: [employeeId], references: [id])
  answer     Answer   @relation(fields: [answerId], references: [id])
  uploadedAt DateTime @default(now())
}
